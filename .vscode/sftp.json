{
    "remote": "bgadev",
    "remotePath": "/burglebros/",
    "uploadOnSave": true,
    "ignore": [
        ".*",
        "CLAUDE.md",
        "_ide_helper.php",
        "bga-framework.d.ts",
        "misc/tests/phpunit.phar",
        "misc/tests/.phpunit.cache",
        "node_modules",
        "build",
        "src",
        "package.json",
        "package-lock.json",
        "tsconfig.json",
        "rollup.config.mjs",
        "flake.nix",
        "flake.lock"
    ],
    "syncOption": {
        "skipCreate": false,
        "delete": true
    },
    "watcher": {
        "files": "**/*.{js,css}",
        "autoUpload": true,
        "autoDelete": true
    }
}
